{
  "name": "tech4value",
  "version": "1.0.0",
  "description": "Validation script to ensure all documents conform to expectations in .doc folder using Claude AI",
  "type": "module",
  "main": "scripts/validate-docs.js",
  "scripts": {
    "validate": "node scripts/validate-docs.js",
    "validate:verbose": "node scripts/validate-docs.js --verbose",
    "check-conformance": "node scripts/validate-docs.js --strict",
    "check-words": "bun scripts/check-word-count.ts",
    "check-video": "bun scripts/check-video-script.ts",
    "odoo:demo:dry-run": "bun scripts/configure-odoo-demo.ts",
    "odoo:demo:apply": "bun scripts/configure-odoo-demo.ts --apply"
  },
  "keywords": [
    "validation",
    "documentation",
    "conformance",
    "claude",
    "ai"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "fs-extra": "^11.2.0",
    "spec-kit": "github/spec-kit"
  },
  "devDependencies": {
    "@types/node": "^25.9.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
